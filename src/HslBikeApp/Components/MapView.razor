@using HslBikeApp.Helpers
@inject AppState State
@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="map-container"></div>

@code {
    private DotNetObjectReference<MapView>? _dotNetRef;
    private bool _mapInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("MapInterop.initMap", "map-container", 60.1699, 24.9384, 13, _dotNetRef);
            _mapInitialized = true;
            State.OnStateChanged += OnStateChanged;
            await UpdateMapAsync();
        }
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(async () => await UpdateMapAsync());
    }

    private async Task UpdateMapAsync()
    {
        if (!_mapInitialized) return;

        var selectedId = State.SelectedStation?.Id;
        await JS.InvokeVoidAsync("MapInterop.setMarkerSelected", selectedId);

        var markers = State.FilteredStations.Select(s =>
        {
            var trend = State.GetTrend(s.Id);
            var (badge, badgeColor) = DisplayHelpers.GetBadge(trend);

            return new
            {
                id = s.Id,
                lat = s.Latitude,
                lon = s.Longitude,
                name = s.Name,
                bikes = s.BikesAvailable,
                capacity = s.Capacity,
                color = DisplayHelpers.GetMarkerColour(s),
                badge,
                badgeColor
            };
        }).ToList();

        await JS.InvokeVoidAsync("MapInterop.updateMarkers",
            System.Text.Json.JsonSerializer.Serialize(markers));

        // Open data sources
        var openDataMarkers = State.OpenDataSeries.Select(series =>
        {
            var latest = series.LatestAvailable();
            var unit = string.IsNullOrWhiteSpace(series.Unit) ? "" : " " + series.Unit;
            var tooltip = latest is { } point
                ? $"<b>{series.DisplayName}</b><br>{FormatValue(point.Value)}{unit}"
                : $"<b>{series.DisplayName}</b><br>Currently unavailable";
            return new
            {
                id = series.SourceId,
                lat = series.Lat,
                lon = series.Lon,
                tooltip
            };
        }).ToList();

        await JS.InvokeVoidAsync("MapInterop.updateOpenDataMarkers",
            System.Text.Json.JsonSerializer.Serialize(openDataMarkers));

        // Cycle lanes
        if (State.ShowCycleLanes && State.CycleLanes.Count > 0)
        {
            var lines = State.CycleLanes.Select(l => new { coords = l.Coordinates }).ToList();
            await JS.InvokeVoidAsync("MapInterop.updatePolylines",
                System.Text.Json.JsonSerializer.Serialize(lines));
        }
        else
        {
            await JS.InvokeVoidAsync("MapInterop.clearPolylines");
        }

        // Destination routes
        if (State.SelectedStation is not null && State.Destinations.Count > 0)
        {
            var fromStation = State.SelectedStation;
            var maxTrips = State.Destinations.Max(d => d.TripCount);
            var routes = State.Destinations.Take(15).Select(d =>
            {
                var toStation = State.Stations.FirstOrDefault(s =>
                    s.Id.Equals(d.ArrivalStationId, StringComparison.OrdinalIgnoreCase));
                if (toStation is null) return null;

                var weight = maxTrips > 0 ? 2 + (double)d.TripCount / maxTrips * 6 : 3;
                return new
                {
                    from = new[] { fromStation.Latitude, fromStation.Longitude },
                    to = new[] { toStation.Latitude, toStation.Longitude },
                    weight,
                    tooltip = $"{toStation.Name}: {d.TripCount} trips, avg {d.AverageDurationFormatted}" +
                              (d.AverageDistanceMetres > 0 ? $", {(d.AverageDistanceMetres / 1000.0):0.1} km" : "")
                };
            }).Where(r => r is not null).ToList();

            await JS.InvokeVoidAsync("MapInterop.updateDestinationRoutes",
                System.Text.Json.JsonSerializer.Serialize(routes));
        }
        else
        {
            await JS.InvokeVoidAsync("MapInterop.clearDestinationRoutes");
        }
    }

    [JSInvokable]
    public async Task OnMarkerClicked(string stationId)
    {
        var station = State.Stations.FirstOrDefault(s => s.Id == stationId);
        if (station is not null)
            await State.SelectStationAsync(station);
    }

    [JSInvokable]
    public void OnOpenDataMarkerClicked(string sourceId) => State.SelectOpenDataSource(sourceId);

    [JSInvokable]
    public void OnMapClicked() => State.ClearSelection();

    private static string FormatValue(double value)
    {
        if (Math.Abs(value - Math.Round(value)) < 0.0001)
            return ((long)Math.Round(value)).ToString(System.Globalization.CultureInfo.InvariantCulture);
        return value.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
    }

    public async ValueTask DisposeAsync()
    {
        State.OnStateChanged -= OnStateChanged;
        _dotNetRef?.Dispose();
    }
}
