#!/bin/sh
# Pre-commit hook: build and run tests before allowing commit

echo "Running pre-commit checks..."

# Build the solution
echo "Building solution..."
dotnet build hsl-bike-app.slnx --configuration Release --verbosity quiet
if [ $? -ne 0 ]; then
    echo "❌ Build failed. Commit aborted."
    exit 1
fi

# Run tests
echo "Running tests..."
dotnet test hsl-bike-app.slnx --no-build --configuration Release --verbosity quiet
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Commit aborted."
    exit 1
fi

echo "✅ All checks passed."
exit 0
