@using System.Globalization
@using HslBikeApp.Helpers

@{
    var trendChevron = DisplayHelpers.GetTrendChevron(Trend);
    var trendExplanation = DisplayHelpers.FormatTrendExplanation(TrendSummary);
}

<div class="detail-panel">
    <div class="drag-handle" aria-hidden="true"></div>

    <div class="detail-panel-header">
        <div class="detail-panel-heading">
            <h2>@Station.Name</h2>
            <div class="meta">@Station.Address</div>
        </div>
        <button class="close-btn" @onclick="OnClose" aria-label="Close station details">&#10005;</button>
    </div>

    <div class="detail-card">
        <h4>Availability</h4>
        <div class="chips">
            @if (!Station.IsActive)
            {
                <span class="chip offline">Offline</span>
            }
            else
            {
                <span class="chip @DisplayHelpers.GetBikeChipClass(Station.BikesAvailable)">
                    &#128690; @Station.BikesAvailable / @Station.Capacity bikes
                </span>
                @if (trendChevron is not null)
                {
                    <span class="chip trend-chip @DisplayHelpers.GetTrendClass(Trend)" title="@trendExplanation">@trendChevron</span>
                }
            }
        </div>

        @if (Station.IsActive && trendExplanation is not null)
        {
            <div class="trend-explanation">@trendExplanation</div>
        }
    </div>

    <div class="detail-card">
        <h4>Availability History</h4>

        @if (SnapshotCounts.Length > 1 && Timestamps.Count > 1)
        {
            <div class="availability-legend">Last @FormatDuration(Timestamps[^1] - Timestamps[0])</div>

            <div class="snapshot-chart-layout">
                <div class="snapshot-y-axis">
                    <span>@((int)Math.Ceiling(ChartMaxY))</span>
                    <span>@((int)Math.Ceiling(ChartMaxY) / 2)</span>
                    <span>0</span>
                </div>
                <div class="snapshot-chart-wrapper">
                    <svg class="snapshot-chart" viewBox="0 0 400 160" preserveAspectRatio="none"
                         aria-label="Bike availability over time">
                        <line class="capacity-line"
                              x1="0" y1="@GetChartY(Station.Capacity)"
                              x2="400" y2="@GetChartY(Station.Capacity)" />

                        @foreach (var segment in GetAreaSegments())
                        {
                            <path class="@segment.CssClass" d="@segment.Path" />
                            <polyline class="snapshot-line @segment.CssClass" points="@segment.LinePoints" />
                        }

                        <circle class="latest-dot"
                                cx="@F(GetChartX(SnapshotCounts.Length - 1))"
                                cy="@F(GetChartY(SnapshotCounts[^1]))" r="4" />
                    </svg>
                    <div class="snapshot-x-axis">
                        @foreach (var tick in BuildXAxisTicks())
                        {
                            <span style="left:@F(tick.Percent)%;">@tick.Label</span>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="availability-empty">No availability history yet.</div>
        }
    </div>

    <div class="detail-card">
        <h4>Station Info</h4>
        <div><strong>Station ID:</strong> @Station.Id</div>
        <div><strong>Status:</strong> @(Station.IsActive ? "Active" : "Offline")</div>
        @if (Station.LastUpdated.HasValue)
        {
            <div><strong>Last updated:</strong> @Station.LastUpdated.Value.ToLocalTime().ToString("HH:mm")</div>
        }
    </div>

    <div class="detail-card">
        <h4>
            <button class="stats-toggle" @onclick="ToggleMonthlyStats">
                @(_showMonthlyStats ? "▾" : "▸") Monthly Stats
            </button>
        </h4>

        @if (_showMonthlyStats)
        {
            @if (IsLoadingStatistics)
            {
                <div class="loading-spinner" style="width:24px;height:24px;border-width:3px;margin:12px auto;"></div>
            }
            else if (Statistics is not null)
            {
                <div class="stats-month">@FormatMonth(Statistics.Month)</div>

                <div class="day-type-toggle" role="group" aria-label="Day type filter">
                    <button class="@GetDayTypeClass(DayType.All)" @onclick="() => SetDayType(DayType.All)">All days</button>
                    <button class="@GetDayTypeClass(DayType.Weekday)" @onclick="() => SetDayType(DayType.Weekday)">Weekdays</button>
                    <button class="@GetDayTypeClass(DayType.Weekend)" @onclick="() => SetDayType(DayType.Weekend)">Weekends</button>
                </div>

                <div class="demand-chart-wrapper">
                    <div class="demand-chart" role="img" aria-label="Departures and arrivals by hour">
                        @{
                            var departures = GetDepartures();
                            var arrivals = GetArrivals();
                            var maxDemand = Math.Max(1, Math.Max(departures.Max(), arrivals.Max()));
                        }
                        @for (var hour = 0; hour < 24; hour++)
                        {
                            var departureHeight = Math.Max(4.0, (double)departures[hour] / maxDemand * 100.0);
                            var arrivalHeight = Math.Max(4.0, (double)arrivals[hour] / maxDemand * 100.0);
                            <div class="demand-column" title="@hour:00 — @departures[hour] dep, @arrivals[hour] arr">
                                <div class="demand-bars">
                                    <div class="demand-bar departure" style="height:@F(departureHeight)%;"></div>
                                    <div class="demand-bar arrival" style="height:@F(arrivalHeight)%;"></div>
                                </div>
                                <div class="demand-hour">@hour.ToString("00", InvariantCulture)</div>
                            </div>
                        }
                    </div>
                </div>
                <div class="demand-legend">
                    <span class="legend-dot departure"></span> Departures
                    <span class="legend-dot arrival"></span> Arrivals
                </div>

                @if (Destinations.Count > 0)
                {
                    <h4 style="margin-top:16px;">Popular Destinations</h4>
                    <ul class="destination-list">
                        @foreach (var destination in Destinations.Take(15))
                        {
                            <li class="destination-item">
                                <div class="destination-icon">&#128205;</div>
                                <div class="destination-info">
                                    <div class="destination-name">@ResolveStationName(destination.ArrivalStationId)</div>
                                    <div class="destination-meta">
                                        @destination.TripCount trips &middot; avg @destination.AverageDurationFormatted
                                        @if (destination.AverageDistanceMetres > 0)
                                        {
                                            <text> &middot; @((destination.AverageDistanceMetres / 1000.0).ToString("0.0", InvariantCulture)) km</text>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            }
            else
            {
                <div style="color:var(--text-secondary);font-size:13px;">No monthly statistics available yet.</div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public required BikeStation Station { get; set; }
    [Parameter] public List<DestinationRow> Destinations { get; set; } = [];
    [Parameter] public bool IsLoadingStatistics { get; set; }
    [Parameter] public MonthlyStationStatistics? Statistics { get; set; }
    [Parameter] public AvailabilityTrend Trend { get; set; }
    [Parameter] public required TrendSummary TrendSummary { get; set; }
    [Parameter] public int[] SnapshotCounts { get; set; } = [];
    [Parameter] public IReadOnlyList<DateTime> Timestamps { get; set; } = [];
    [Parameter] public Func<int, bool>? IsGap { get; set; }
    [Parameter] public List<BikeStation> AllStations { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnToggleMonthlyStats { get; set; }

    private static readonly CultureInfo InvariantCulture = CultureInfo.InvariantCulture;
    private bool _showMonthlyStats;
    private DayType _selectedDayType = DayType.All;

    private enum DayType { All, Weekday, Weekend }

    private async Task ToggleMonthlyStats()
    {
        _showMonthlyStats = !_showMonthlyStats;
        if (_showMonthlyStats)
        {
            await OnToggleMonthlyStats.InvokeAsync();
        }
    }

    private void SetDayType(DayType dayType) => _selectedDayType = dayType;

    private int[] GetDepartures() => _selectedDayType switch
    {
        DayType.Weekday => Statistics?.Demand.WeekdayDeparturesByHour ?? [],
        DayType.Weekend => Statistics?.Demand.WeekendDeparturesByHour ?? [],
        _ => Statistics?.Demand.DeparturesByHour ?? []
    };

    private int[] GetArrivals() => _selectedDayType switch
    {
        DayType.Weekday => Statistics?.Demand.WeekdayArrivalsByHour ?? [],
        DayType.Weekend => Statistics?.Demand.WeekendArrivalsByHour ?? [],
        _ => Statistics?.Demand.ArrivalsByHour ?? []
    };

    private string GetDayTypeClass(DayType dayType) =>
        _selectedDayType == dayType ? "day-type-btn active" : "day-type-btn";

    private double ChartMaxY => SnapshotCounts.Length > 0
        ? Math.Max(Station.Capacity > 0 ? Station.Capacity : 1, SnapshotCounts.Max())
        : 1;

    private double GetChartX(int index)
    {
        if (SnapshotCounts.Length <= 1) return 0;
        return 400.0 * index / (SnapshotCounts.Length - 1);
    }

    private double GetChartY(int count) =>
        140.0 - (count / ChartMaxY * 130.0) + 5;

    private record AreaSegment(string Path, string LinePoints, string CssClass);

    private List<AreaSegment> GetAreaSegments()
    {
        var segments = new List<AreaSegment>();
        var startIndex = 0;

        for (var index = 0; index <= SnapshotCounts.Length; index++)
        {
            var isEnd = index == SnapshotCounts.Length;
            var isGapHere = !isEnd && index > 0 && (IsGap?.Invoke(index) ?? false);

            if (isEnd || isGapHere)
            {
                if (index > startIndex)
                    segments.Add(BuildSegment(startIndex, index - 1));
                startIndex = index;
            }
        }

        return segments;
    }

    private AreaSegment BuildSegment(int from, int to)
    {
        var points = new List<string>();
        var linePoints = new List<string>();

        for (var index = from; index <= to; index++)
        {
            var x = GetChartX(index);
            var y = GetChartY(SnapshotCounts[index]);
            points.Add($"{F(x)},{F(y)}");
            linePoints.Add($"{F(x)},{F(y)}");
        }

        var averageRatio = to >= from
            ? Enumerable.Range(from, to - from + 1)
                .Average(index => Station.Capacity > 0 ? (double)SnapshotCounts[index] / Station.Capacity : 0)
            : 0;

        var cssClass = averageRatio switch
        {
            < 0.1 => "zone-red",
            < 0.3 => "zone-amber",
            _ => "zone-green"
        };

        var firstX = F(GetChartX(from));
        var lastX = F(GetChartX(to));
        var baseline = F(145.0);
        var path = $"M {firstX},{baseline} L {string.Join(" L ", points)} L {lastX},{baseline} Z";

        return new AreaSegment(path, string.Join(" ", linePoints), cssClass);
    }

    private string ResolveStationName(string stationId)
    {
        var station = AllStations.FirstOrDefault(candidate =>
            candidate.Id.Equals(stationId, StringComparison.OrdinalIgnoreCase));
        return station?.Name ?? stationId;
    }

    private static string FormatMonth(string month)
    {
        if (DateTime.TryParseExact(month, "yyyy-MM", InvariantCulture, DateTimeStyles.None, out var date))
            return date.ToString("MMMM yyyy", InvariantCulture);
        return month;
    }

    private static string FormatDuration(TimeSpan span)
    {
        var totalMinutes = Math.Max(0, (int)Math.Round(span.TotalMinutes));
        if (totalMinutes < 60) return $"{totalMinutes} min";

        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;
        return minutes == 0 ? $"{hours} h" : $"{hours} h {minutes} min";
    }

    private record XAxisTick(double Percent, string Label);

    private List<XAxisTick> BuildXAxisTicks()
    {
        var ticks = new List<XAxisTick>();
        if (Timestamps.Count < 2) return ticks;

        var latest = Timestamps[^1];
        var earliest = Timestamps[0];
        var totalMinutes = (latest - earliest).TotalMinutes;
        if (totalMinutes <= 0) return ticks;

        // Always anchor the right edge at "now".
        ticks.Add(new XAxisTick(100, "now"));

        // Pick a step so we get roughly 3-5 ticks across the chart.
        var totalHours = totalMinutes / 60.0;
        var stepHours = totalHours switch
        {
            <= 2 => 0.5,
            <= 6 => 1,
            <= 12 => 2,
            <= 24 => 4,
            _ => 6
        };

        for (var hoursAgo = stepHours; hoursAgo <= totalHours + 0.01; hoursAgo += stepHours)
        {
            var minutesAgo = hoursAgo * 60;
            var percent = 100.0 - (minutesAgo / totalMinutes * 100.0);
            if (percent < 2) break;

            var label = stepHours < 1
                ? $"{(int)Math.Round(minutesAgo)} min ago"
                : $"{hoursAgo:0.#} h ago";
            ticks.Add(new XAxisTick(percent, label));
        }

        return ticks;
    }

    private static string F(double value) => value.ToString("0.##", InvariantCulture);
}
